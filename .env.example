# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/database"

# Supabase Configuration
SUPABASE_URL="https://xvnxmypqmxzjkbmgtkzf.supabase.co"
SUPABASE_SERVICE_KEY="your_service_role_key_here"
SUPABASE_STORAGE_BUCKET="video"

# Server Configuration
PORT=5001

# Judge0 API (optional, for code execution)
JUDGE0_API_KEY="your_judge0_api_key"

# OpenAI API (optional, for agent LLM analysis)
OPENAI_API_KEY="your_openai_api_key"

# Figma design space (for Design tab in assessments)
FIGMA_ACCESS_TOKEN="your_figma_personal_access_token"
FIGMA_TEMPLATE_FILE_ID="your_figma_file_key"

# Google Sheets (for Sheets tab: duplicate template per candidate, shareable link)
# Option A — OAuth (recommended: copy goes to YOUR Drive, uses your 2TB). Same account must OWN or have Editor on the template.
# Create OAuth client ID (Desktop) in Google Cloud Console, then run: node scripts/get-google-refresh-token.js
GOOGLE_CLIENT_ID="your_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_oauth_client_secret"
GOOGLE_REFRESH_TOKEN="your_refresh_token_from_get_token_script"
# Option B — Service account (copy goes to service account Drive, limited quota). Share template with client_email as Editor.
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...,"client_email":"...@....iam.gserviceaccount.com",...}'
# Template spreadsheet ID (from the sheet URL: /d/SPREADSHEET_ID/edit). Must be owned or shared with the OAuth account (Option A) or service account (Option B).
SHEETS_TEMPLATE_ID="your_google_spreadsheet_id"

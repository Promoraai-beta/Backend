generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  name               String
  role               String
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  candidateProfile   CandidateProfile?
  passwordResetCodes PasswordResetCode[]
  recruiterProfile   RecruiterProfile?
  sessions           Session[]

  @@map("users")
}

model CandidateProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  title                String?
  location             String?
  bio                  String?
  avatar               String?
  skills               Json?
  interests            Json?
  targetRole           String?  @map("target_role")
  promptIQScore        Int      @default(0) @map("prompt_iq_score")
  totalPoints          Int      @default(0) @map("total_points")
  level                String?  @default("Beginner")
  assessmentsCompleted Int      @default(0) @map("assessments_completed")
  achievements         Json?
  isPublic             Boolean  @default(false) @map("is_public")
  joinedDate           DateTime @default(now()) @map("joined_date")
  onboardingCompleted  Boolean  @default(false) @map("onboarding_completed")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("candidate_profiles")
}

model RecruiterProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  companyId           String?  @map("company_id")
  position            String?
  department          String?
  avatar              String?
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  company             Company? @relation(fields: [companyId], references: [id])
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recruiter_profiles")
}

model Company {
  id          String             @id @default(uuid())
  name        String
  industry    String?
  size        String?
  location    String?
  website     String?
  description String?
  logo        String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  assessments Assessment[]
  invitations Invitation[]
  recruiters  RecruiterProfile[]

  @@map("companies")
}

model Invitation {
  id          String    @id @default(uuid())
  token       String    @unique
  email       String?
  companyId   String?   @map("company_id")
  companyName String?   @map("company_name")
  role        String    @default("recruiter")
  usedBy      String?   @map("used_by")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String?   @map("created_by")
  company     Company?  @relation(fields: [companyId], references: [id])

  @@index([token])
  @@index([email])
  @@map("invitations")
}

model PasswordReset {
  id        String    @id @default(uuid())
  email     String
  code      String
  token     String    @unique
  used      Boolean   @default(false)
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([code])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model Template {
  id                   String       @id @default(uuid())
  templateHash         String       @unique @map("template_hash")
  role                 String?
  techStack            Json?        @map("tech_stack")
  level                String?
  templateSpec         Json         @map("template_spec")
  suggestedAssessments Json?        @map("suggested_assessments")
  dockerImage          String?      @map("docker_image")
  dockerImageBuilt     Boolean      @default(false) @map("docker_image_built")
  webcontainerReady    Boolean      @default(false) @map("webcontainer_ready")
  buildStatus          String       @default("pending") @map("build_status")
  buildError           String?      @map("build_error")
  usageCount           Int          @default(0) @map("usage_count")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  assessments          Assessment[]
  assessmentVariants   AssessmentVariant[]
  assignedSessions     Session[]          @relation("SessionAssignedVariant")

  @@index([templateHash])
  @@index([role, level])
  @@index([buildStatus])
  @@map("templates")
}

model Assessment {
  id             String    @id @default(uuid())
  jobTitle       String?   @map("job_title")
  companyId      String?   @map("company_id")
  jobDescription String?   @map("job_description")
  role           String?
  techStack      Json?     @map("tech_stack")
  level          String?
  templateId     String?   @map("template_id")
  template       Json?
  sourceUrl      String?   @map("source_url")
  sourceType     String?   @map("source_type")
  assessmentType String?            @default("recruiter") @map("assessment_type")
  isActive       Boolean            @default(true) @map("is_active")
  createdBy      String?            @map("created_by")
  variantCount   Int?               @map("variant_count") // null = 1 (single-template mode)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  company        Company?           @relation(fields: [companyId], references: [id])
  templateRef    Template?          @relation(fields: [templateId], references: [id])
  sessions       Session[]
  variants       AssessmentVariant[]

  @@index([level])
  @@index([role])
  @@index([isActive])
  @@index([templateId])
  @@map("assessments")
}

// Stores the N template variants generated for an assessment.
// variantIndex is 0-based. Session assignment = sessionCount % variantCount → variantIndex.
model AssessmentVariant {
  id           String     @id @default(uuid())
  assessmentId String     @map("assessment_id")
  templateId   String     @map("template_id")
  variantIndex Int        @map("variant_index") // 0, 1, 2, ...
  createdAt    DateTime   @default(now()) @map("created_at")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  template     Template   @relation(fields: [templateId], references: [id])

  @@unique([assessmentId, variantIndex])
  @@index([assessmentId])
  @@map("assessment_variants")
}

model Session {
  id                    String          @id @default(uuid())
  sessionCode           String          @unique @map("session_code")
  candidateId           String?         @map("candidate_id")
  candidateName         String?         @map("candidate_name")
  candidateEmail        String?         @map("candidate_email")
  recruiterEmail        String?         @map("recruiter_email")
  assessmentId          String?         @map("assessment_id")
  status                String          @default("pending")
  startedAt             DateTime?       @map("started_at")
  submittedAt           DateTime?       @map("submitted_at")
  timeLimit             Int             @default(3600) @map("time_limit")
  selectedLlm           String?         @map("selected_llm")
  finalCode             String?         @map("final_code")
  expiresAt             DateTime?       @map("expires_at")
  lastActivityAt        DateTime?       @map("last_activity_at")
  tabSwitchCount        Int             @default(0) @map("tab_switch_count")
  lastTabSwitchAt       DateTime?       @map("last_tab_switch_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  assignedVariantId     String?         @map("assigned_variant_id") // null = use assessment.templateRef
  containerId           String?         @map("container_id")
  containerUrl          String?         @map("container_url")
  containerStatus       String?         @default("pending") @map("container_status") // pending | provisioning | ready | failed
  figmaFileUrl          String?         @map("figma_file_url")
  figmaResourceId       String?         @map("figma_resource_id")
  sheetsFileUrl         String?         @map("sheets_file_url")
  sheetsResourceId      String?         @map("sheets_resource_id")
  previewUrl            String?         @map("preview_url")
  supportsDirectPreview Boolean         @default(false) @map("supports_direct_preview")
  toolResources         Json?           @map("tool_resources")
  agentInsights         AgentInsight?
  aiInteractions        AiInteraction[]
  codeSnapshots         CodeSnapshot[]
  events                Event[]
  mcpInsights           McpInsight[]
  assessment            Assessment?     @relation(fields: [assessmentId], references: [id])
  candidate             User?           @relation(fields: [candidateId], references: [id])
  assignedVariant       Template?       @relation("SessionAssignedVariant", fields: [assignedVariantId], references: [id])
  submissions           Submission[]

  @@index([sessionCode])
  @@index([status])
  @@index([assessmentId])
  @@index([lastActivityAt])
  @@map("sessions")
}

model CodeSnapshot {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  timestamp DateTime @default(now())
  code      String
  lineCount Int      @map("line_count")
  language  String
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("code_snapshots")
}

model Event {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  eventType String   @map("event_type")
  timestamp DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([eventType])
  @@map("events")
}


model Submission {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  problemId   Int?     @map("problem_id")
  code        String
  language    String
  testResults Json?    @map("test_results")
  score       Int      @default(0)
  passedTests Int      @default(0) @map("passed_tests")
  totalTests  Int      @default(0) @map("total_tests")
  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([problemId])
  @@map("submissions")
}

model AiInteraction {
  id               String   @id @default(uuid())
  sessionId        String   @map("session_id")
  eventType        String   @map("event_type")
  timestamp        DateTime @default(now())
  model            String?
  promptText       String?  @map("prompt_text")
  responseText     String?  @map("response_text")
  tokensUsed       Int?     @map("tokens_used")
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  latencyMs        Int?     @map("latency_ms")
  tabId            String?  @map("tab_id")
  conversationTurn Int?     @map("conversation_turn")
  codeSnippet      String?  @map("code_snippet")
  codeLineNumber   Int?     @map("code_line_number")
  codeBefore       String?  @map("code_before")
  codeAfter        String?  @map("code_after")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([eventType])
  @@index([timestamp])
  @@index([sessionId, timestamp])
  @@map("ai_interactions")
}

model AgentInsight {
  id                  String   @id @default(uuid())
  sessionId           String   @unique @map("session_id")
  watcher             Json?
  extractor           Json?
  sanity              Json?
  computedAt          DateTime @default(now()) @map("computed_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  version             Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at")
  judge               Json?
  geminiVideoAnalysis Json?    @map("gemini_video_analysis")
  session             Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([computedAt])
  @@map("agent_insights")
}

model McpInsight {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  source    String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, source])
  @@map("mcp_insights")
}

model PasswordResetCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  email     String
  code      String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([userId])
  @@index([code])
  @@index([createdAt])
  @@map("password_reset_codes")
}
